# Copy to .env and fill in. The app reads these via os.getenv.

# Required: any OpenAI-compatible API key.
OPENAI_API_KEY= 'insert key here'


# Optional: override to use a different OpenAI-compatible provider.
# Default: https://api.openai.com/v1
# Groq example: https://api.groq.com/openai/v1
# Local Ollama:  http://localhost:11434/v1
# OPENAI_BASE_URL=https://api.openai.com/v1

# Optional: override the model. Default is gpt-4o-mini.
# MODEL_NAME=gpt-4o-mini



